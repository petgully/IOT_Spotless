# ESP32 per-site config (contains WiFi credentials + Pi static IP).
# Each node ships with a config.h.example committed; operators copy it to
# config.h on their machine via tools/flash_node.ps1 (or by hand) and fill
# in real values that must NEVER be committed.
esp32_node1/include/config.h
esp32_node2/include/config.h
esp32_node3/include/config.h

# Runtime config (created on Pi at runtime)
.spotless/

# Node.js (if any)
node_modules/

# Cursor workspace-private scratch (commit messages, temp scripts)
.cursor/commit_msg.txt
.cursor/tmp_*.py
.cursor/tmp_*.json

# Kiosk runtime data (session SQLite, cloud-write queue, session logs)
raspberry_pi/data/
