# =============================================================================
# Project Spotless - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# `bootstrap.sh` will generate this file for you on a fresh Pi.
#
# After any edits:  sudo systemctl restart spotless-kiosk
# =============================================================================

# --- Machine identity ---
# Should match ~/.spotless/machine_id.txt — used as a fallback / for logs.
SPOTLESS_MACHINE_ID=BS01

# --- AWS RDS Aurora MySQL ---
# Get the endpoint from AWS RDS Console → Your Aurora Cluster → Endpoints.
# Leave blank to run in offline mode (sessions logged locally only).
SPOTLESS_DB_HOST=your-aurora-endpoint.cluster-xxxxx.us-east-1.rds.amazonaws.com
SPOTLESS_DB_PORT=3306
SPOTLESS_DB_USER=spotless001
SPOTLESS_DB_PASSWORD=your-password-here
SPOTLESS_DB_NAME=petgully_db
SPOTLESS_DB_SSL=true

# --- SpotlessBooking API ---
# Optional shared secret. Must match KIOSK_API_KEY on the booking server.
# Leave blank for now; set later when the booking team provisions one
# (see docs/KIOSK_INTEGRATION_HANDOVER.md §5.2).
KIOSK_API_KEY=

# --- Admin UI password ---
# HTTP Basic Auth on http://<pi-ip>:5000/admin (Phase 3 operator console).
# Username is fixed at "admin"; this is the password.
# Leave at the default ("spotless-admin") for first boot, but the admin
# dashboard will show a yellow banner until you change it. To rotate:
#   1. Edit this file
#   2. sudo systemctl restart spotless-kiosk
SPOTLESS_ADMIN_PASSWORD=change-me-please

# --- MQTT Broker (only override for non-local brokers) ---
# MQTT_BROKER=localhost
# MQTT_PORT=1883

# --- Email Configuration (optional) ---
# Leave blank to disable email notifications.
# EMAIL_SENDER=spotlessbs02@gmail.com
# EMAIL_PASSWORD=your-gmail-app-password
# EMAIL_RECEIVER=management@petgully.com
